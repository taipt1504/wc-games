// WC2026 Prediction Game — Prisma schema
// Dịch từ DDL trong docs/solution-design (Prediction/Auth/Data/Supporting Service Design).
// Lưu ý: schema này là SOURCE OF TRUTH; DDL trong tài liệu là SQL minh hoạ.
// Tiền (point) dùng BigInt (khớp BIGINT) → khi trả JSON cần serialize BigInt (xem README).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────
enum Role {
  USER
  MOD
  ADMIN
  OPS
  SUPER
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum ContextType {
  GLOBAL
  LOBBY
}

enum LedgerType {
  SIGNUP
  DAILY
  LOBBY_DEFAULT
  STAKE
  SETTLE
  VOID
  BORROW
  REFERRAL
  PURCHASE
  ADMIN_ADJ
  BONUS
}

// Outcome map: HOME='1', DRAW='X', AWAY='2'
enum Outcome {
  HOME
  DRAW
  AWAY
}

enum PredictionStatus {
  OPEN
  LOCKED
  WON
  LOST
  VOID
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchRound {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
}

enum SettlementStatus {
  DONE
  PENDING_REVIEW
  VOID
}

enum OddsSource {
  API
  AI
  ADMIN
  LOBBY
}

enum LobbyScope {
  ALL
  GROUP
  R32
  R16
  QF
  SF
  FINAL
  MATCH
}

enum LobbyRole {
  OWNER
  MEMBER
}

enum BorrowStatus {
  PENDING
  APPROVED
  DENIED
}

enum NewsStatus {
  PENDING
  PUBLISHED
  REJECTED
  UNPUBLISHED
}

enum ReferralStatus {
  PENDING
  ACTIVATED
  REJECTED
}

enum FutureMarket {
  CHAMPION
  GOLDEN_BOOT
  GOLDEN_BALL
  FINALIST
}

enum DuelStatus {
  PENDING
  ACTIVE
  DONE
}

enum MessageKind {
  TEXT
  SYSTEM
  REACTION
}

// ─────────────────────────── AUTH & ACCOUNT ───────────────────────────
model User {
  id           BigInt     @id @default(autoincrement())
  email        String     @unique
  username     String?    @unique
  passwordHash String
  displayName  String?
  avatarUrl    String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  tier         String?
  createdAt    DateTime   @default(now())

  sessions    AuthSession[]
  wallets     Wallet[]
  predictions Prediction[]
  memberships LobbyMembership[]
}

model AuthSession {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt
  refreshTokenHash String
  ip               String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Password reset (AUTH-08). Token is stored hashed; email delivery is deferred infra.
model PasswordReset {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  actorType String // USER | ADMIN | SYSTEM
  actorId   BigInt?
  action    String
  target    String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorType, actorId, createdAt])
  @@index([ip])
}

model ReferralCode {
  userId BigInt @id
  code   String @unique
}

model Referral {
  id         BigInt         @id @default(autoincrement())
  referrerId BigInt
  refereeId  BigInt         @unique
  status     ReferralStatus @default(PENDING)
  createdAt  DateTime       @default(now())

  @@index([referrerId])
}

// ─────────────────────────── WALLET & LEDGER (Prediction SD §6) ───────────────────────────
model Wallet {
  id          BigInt      @id @default(autoincrement())
  userId      BigInt
  contextType ContextType
  contextId   BigInt? // null nếu GLOBAL
  balance     BigInt      @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, contextType, contextId])
}

model PointLedger {
  id           BigInt      @id @default(autoincrement())
  userId       BigInt
  contextType  ContextType
  contextId    BigInt?
  type         LedgerType
  amount       BigInt // +/-
  balanceAfter BigInt
  refType      String?
  refId        BigInt?
  createdAt    DateTime    @default(now())

  @@index([userId, contextType, contextId, createdAt])
  @@index([refType, refId])
}

// ─────────────────────────── PREDICTION & SCORING ───────────────────────────
model Prediction {
  id           BigInt           @id @default(autoincrement())
  userId       BigInt
  contextType  ContextType
  contextId    BigInt?
  matchId      BigInt
  market       String           @default("1X2")
  outcome      Outcome
  stake        BigInt
  oddsSnapshot Decimal          @db.Decimal(6, 2)
  exactHome    Int?
  exactAway    Int?
  powerUp      String? // DEPTH-04: DOUBLE_DOWN | INSURANCE applied to this bet
  status       PredictionStatus @default(OPEN)
  payout       BigInt           @default(0)
  settledAt    DateTime?
  createdAt    DateTime         @default(now())

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  // 1 bet per OUTCOME / match / context (allows hedging A/X/2 on the same fixture)
  @@unique([userId, contextType, contextId, matchId, market, outcome], map: "prediction_ctx_match_market_outcome_uq")
  @@index([matchId, status])
  @@index([userId, contextType, contextId, createdAt])
}

model Settlement {
  matchId   BigInt           @id
  status    SettlementStatus
  result90  Outcome?
  settledAt DateTime?
  settledBy String           @default("SYSTEM")
}

// Aggregate cho leaderboard ROI — CHỈ tổng hợp kèo context=GLOBAL (kèo lobby KHÔNG ghi vào đây).
model PredictionUserStats {
  userId        BigInt @id
  totalStaked   BigInt @default(0)
  totalReturned BigInt @default(0)
  settledCount  Int    @default(0)
  winCount      Int    @default(0)
}

model Bracket {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @unique
  picks     Json // {"R16":[teamIds],...,"CHAMPION":teamId}
  lockedAt  DateTime?
  score     Int       @default(0)
  updatedAt DateTime  @updatedAt
}

model FuturePick {
  id           BigInt           @id @default(autoincrement())
  userId       BigInt
  market       FutureMarket
  selectionId  BigInt
  stake        BigInt
  oddsSnapshot Decimal          @db.Decimal(6, 2)
  status       PredictionStatus @default(OPEN)
  payout       BigInt           @default(0)
  createdAt    DateTime         @default(now())

  @@index([userId])
}

// ─────────────────────────── TOURNAMENT DATA (Data SD §7) ───────────────────────────
model Group {
  id    BigInt @id @default(autoincrement())
  name  String @unique // A..L
  teams Team[]
}

model Team {
  id      BigInt   @id @default(autoincrement())
  name    String
  code    String?
  flagUrl String?
  fifaRank Int?
  groupId BigInt?
  formation String? // e.g. "4-2-3-1" (AI-crawled lineup)
  manager   String? // head coach (AI-crawled)

  group   Group?   @relation(fields: [groupId], references: [id])
  players Player[]
}

model Venue {
  id      BigInt @id @default(autoincrement())
  name    String
  city    String?
  country String?
}

model Player {
  id        BigInt  @id @default(autoincrement())
  teamId    BigInt
  name      String
  position  String? // specific role: GK/RB/CB/LB/CDM/CM/CAM/RW/LW/ST/... (AI-crawled)
  number    Int?
  isStarter Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId])
}

model Match {
  id          BigInt      @id @default(autoincrement())
  round       MatchRound
  groupId     BigInt?
  homeTeamId  BigInt
  awayTeamId  BigInt
  venueId     BigInt?
  kickoffAt   DateTime
  status      MatchStatus @default(SCHEDULED)
  scoreHome90 Int?
  scoreAway90 Int?
  result90    Outcome?
  source      OddsSource?
  bettingLocked Boolean   @default(false) // admin can block betting on this match (PRD §09)
  updatedAt   DateTime    @updatedAt

  odds        MatchOdds?
  predictions Prediction[]

  @@index([kickoffAt])
  @@index([status])
}

model MatchOdds {
  matchId   BigInt     @id
  mHome     Decimal    @db.Decimal(6, 2)
  mDraw     Decimal    @db.Decimal(6, 2)
  mAway     Decimal    @db.Decimal(6, 2)
  source    OddsSource @default(API)
  updatedAt DateTime   @updatedAt

  match Match @relation(fields: [matchId], references: [id])
}

// Per-lobby host odds override (FR-LOBBY-07). Falls back to global MatchOdds when absent.
model LobbyMatchOdds {
  id        BigInt   @id @default(autoincrement())
  lobbyId   BigInt
  matchId   BigInt
  mHome     Decimal  @db.Decimal(6, 2)
  mDraw     Decimal  @db.Decimal(6, 2)
  mAway     Decimal  @db.Decimal(6, 2)
  updatedAt DateTime @updatedAt

  @@unique([lobbyId, matchId])
}

// ─────────────────────────── NEWS & AI ───────────────────────────
model NewsArticle {
  id          BigInt     @id @default(autoincrement())
  title       String
  body        String?
  tags        String[]
  sourceUrl   String?
  aiJobId     BigInt?
  status      NewsStatus @default(PENDING)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())

  @@index([status, publishedAt])
}

model AiJob {
  id           BigInt   @id @default(autoincrement())
  type         String // ingest | news | odds | preview
  providerUsed String? // claude | openai
  status       String
  tokens       Int?
  cost         Decimal? @db.Decimal(10, 4)
  latencyMs    Int?
  error        String?
  createdAt    DateTime @default(now())
}

model AiPreview {
  matchId     BigInt   @id
  content     Json
  provider    String?
  generatedAt DateTime @default(now())
}

// ─────────────────────────── LOBBY ───────────────────────────
model Lobby {
  id            BigInt     @id @default(autoincrement())
  ownerId       BigInt
  name          String?
  passwordHash  String?
  inviteToken   String     @unique
  scope         LobbyScope
  scopeRefId    BigInt? // matchId nếu scope=MATCH
  defaultPoints BigInt
  allowBorrow   Boolean    @default(true)
  manualOdds    Boolean    @default(false)
  status        String     @default("OPEN")
  createdAt     DateTime   @default(now())

  memberships LobbyMembership[]
  messages    LobbyMessage[]
}

model LobbyMembership {
  id            BigInt    @id @default(autoincrement())
  lobbyId       BigInt
  userId        BigInt
  role          LobbyRole @default(MEMBER)
  defaultPoints BigInt
  borrowed      BigInt    @default(0)
  joinedAt      DateTime  @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([lobbyId, userId])
}

model BorrowRequest {
  id           BigInt       @id @default(autoincrement())
  lobbyId      BigInt
  membershipId BigInt
  amount       BigInt
  status       BorrowStatus @default(PENDING)
  decidedBy    BigInt?
  decidedAt    DateTime?
  createdAt    DateTime     @default(now())

  @@index([lobbyId])
}

model LobbyMessage {
  id        BigInt      @id @default(autoincrement())
  lobbyId   BigInt
  userId    BigInt
  body      String
  kind      MessageKind @default(TEXT)
  createdAt DateTime    @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id])

  @@index([lobbyId, createdAt])
}

// ─────────────────────────── ENGAGEMENT ───────────────────────────
model Streak {
  userId        BigInt    @id
  checkinStreak Int       @default(0)
  winStreak     Int       @default(0)
  lastCheckinDate DateTime?
}

model Mission {
  id     BigInt @id @default(autoincrement())
  code   String @unique
  rule   Json
  reward BigInt
}

model MissionProgress {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  missionId BigInt
  date      DateTime @db.Date
  progress  Int      @default(0)
  claimed   Boolean  @default(false)

  @@unique([userId, missionId, date])
}

model Achievement {
  id        BigInt @id @default(autoincrement())
  code      String @unique
  condition Json
}

model UserAchievement {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  achievementId BigInt
  earnedAt      DateTime @default(now())

  @@unique([userId, achievementId])
}

model Notification {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt
  type      String
  channel   String // PUSH | EMAIL | IN_APP
  payload   Json
  status    String    @default("PENDING")
  sentAt    DateTime?
  readAt    DateTime? // in-app feed: null = unread
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

model NotificationPref {
  id      BigInt  @id @default(autoincrement())
  userId  BigInt
  type    String
  channel String
  enabled Boolean @default(true)

  @@unique([userId, type, channel])
}

// ─────────────────────────── SOCIAL ───────────────────────────
model Duel {
  id           BigInt     @id @default(autoincrement())
  challengerId BigInt
  opponentId   BigInt
  scope        String
  status       DuelStatus @default(PENDING)
  winnerId     BigInt?
  createdAt    DateTime   @default(now())
}

// Cosmetic shop (AIMETA-02) — point sink: buy avatar/frame/theme cosmetics with points.
model CosmeticItem {
  id    BigInt @id @default(autoincrement())
  code  String @unique
  name  String
  kind  String // avatar | frame | theme
  price BigInt
}

model UserCosmetic {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt
  itemId     BigInt
  equipped   Boolean  @default(false)
  acquiredAt DateTime @default(now())

  @@unique([userId, itemId])
}

// DEPTH-04 power-up inventory (Double Down / Insurance / Streak Shield).
model PowerUp {
  id     BigInt @id @default(autoincrement())
  userId BigInt
  type   String // DOUBLE_DOWN | INSURANCE | STREAK_SHIELD
  qty    Int    @default(0)

  @@unique([userId, type])
}

// DEPTH-05 combo/parlay — multiple legs; pays only if ALL legs win.
model Parlay {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  stake     BigInt
  status    String   @default("OPEN") // OPEN | WON | LOST
  payout    BigInt   @default(0)
  createdAt DateTime @default(now())

  legs ParlayLeg[]
}

model ParlayLeg {
  id           BigInt  @id @default(autoincrement())
  parlayId     BigInt
  matchId      BigInt
  outcome      Outcome
  oddsSnapshot Decimal @db.Decimal(6, 2)
  result       String? // PENDING | WON | LOST

  parlay Parlay @relation(fields: [parlayId], references: [id])

  @@index([matchId])
}

// DEPTH-06 in-play micro-prediction (placed during a LIVE match).
model MicroPrediction {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt
  matchId      BigInt
  market       String // NEXT_GOAL | ...
  pick         String
  stake        BigInt
  oddsSnapshot Decimal  @db.Decimal(6, 2)
  status       String   @default("OPEN") // OPEN | WON | LOST
  payout       BigInt   @default(0)
  createdAt    DateTime @default(now())
}

// ─────────────────────────── ADMIN & RISK ───────────────────────────
model RiskFlag {
  id         BigInt   @id @default(autoincrement())
  targetType String // USER | LOBBY
  targetId   BigInt
  rule       String
  severity   String
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
}

model ModerationAction {
  id         BigInt   @id @default(autoincrement())
  adminId    BigInt
  targetType String
  targetId   BigInt
  action     String
  reason     String?
  createdAt  DateTime @default(now())
}

model CaseFile {
  id          BigInt   @id @default(autoincrement())
  subject     String
  evidenceRef String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
}

// Worker schedule-job registry — DB-backed thresholds + enable/disable + last-run status.
// schedule.ts constants are the defaults/fallbacks; @wc/pipeline job-config reads through this.
model ScheduleJob {
  key           String    @id
  label         String
  enabled       Boolean   @default(true)
  config        Json
  lastRunAt     DateTime?
  lastRunStatus String?
  lastRunNote   String?
  updatedBy     BigInt?
  updatedAt     DateTime  @updatedAt
}
