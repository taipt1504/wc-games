# ─────────── Core infra ───────────
NODE_ENV=development
DATABASE_URL=postgresql://wc:wc@localhost:5432/wc_game?schema=public
REDIS_URL=redis://localhost:6379

# ─────────── Web app ───────────
WEB_PORT=3000
APP_BASE_URL=http://localhost:3000

# ─────────── Auth (PRD §16 / Auth SD) ───────────
JWT_SECRET=change-me-in-prod
ACCESS_TTL=15m
REFRESH_TTL=30d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# ─────────── Scoring config (PRD §04.10) ───────────
TIMEZONE=Asia/Ho_Chi_Minh        # UTC+7 — mốc ngày điểm danh/missions
SIGNUP_BONUS=1000
DAILY_CHECKIN=200
MIN_STAKE=1
KNOCKOUT_BONUS_RATE=1.0
UNDERDOG_THRESHOLD=2.0
LEADERBOARD_MIN_SETTLED=10

# ─────────── LLM gateway = 9router (ADR-0005, đã self-host) ───────────
LLM_GATEWAY_BASE_URL=http://localhost:20128/v1   # endpoint OpenAI-compatible team cung cấp
LLM_GATEWAY_API_KEY=change-me
LLM_MODEL_PRIMARY=claude            # Claude (Anthropic) — primary
LLM_MODEL_FALLBACK=gpt              # OpenAI — fallback (hoặc để 9router tự fallback)
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=2

# ─────────── Data / odds providers (PRD §15, free-first) ───────────
SPORTS_API_BASE_URL=
SPORTS_API_KEY=
ODDS_API_BASE_URL=
ODDS_API_KEY=

# ─────────── Object storage (share card / asset) ───────────
S3_ENDPOINT=
S3_BUCKET=wc-game
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─────────── Web push / email (notifications) ───────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
SMTP_URL=
